{
  "version": "v1.0",
  "required_fields": ["name", "category"],
  "category_requirements": {
    "header": ["scss", "lock_policy", "header_variants"],
    "footer": ["xml", "lock_policy", "footer_variants"],
    "dynamic": ["xml", "html", "lock_policy"]
  },
  "lock_policy_requirements": {
    "scss_only": {
      "forbid": ["xml"],
      "require_any": ["scss"]
    },
    "xpath_required": {
      "require_any": ["xml"]
    },
    "structure_locked": {
      "require_all": ["structure_locked", "allowed_ops", "forbidden_ops"]
    }
  }
}
