{
  "version": "v1.0",
  "command": "/page",
  "task_type": "page",
  "intent_summary": "Compose a full page using existing templates with header/footer rules enforced.",
  "header_variant": "menu-1",
  "footer_variant": "footer-1",
  "output_mode": "qweb_full",
  "resources": {
    "templates": [
      {
        "name": "header-menus",
        "path": "templates/header-menus.scss",
        "structure_locked": false,
        "allowed_ops": ["scss_override_only"]
      },
      {
        "name": "footerwcalltoaction-1",
        "path": "templates/footerwcalltoaction-1.xml"
      },
      {
        "name": "base-dynamic-products",
        "path": "templates/base-dynamic-products.xml",
        "structure_locked": true,
        "allowed_ops": [
          "section_class_add",
          "section_data_custom_name_set",
          "scss_override_only"
        ],
        "forbidden_ops": [
          "inner_dom_insert",
          "inner_dom_delete",
          "template_key_change",
          "xml_replace",
          "xml_modify"
        ]
      }
    ],
    "docs": [
      "resources/header_footer_rules.md",
      "resources/dynamic_rules.md"
    ]
  },
  "constraints": {
    "rules": [
      "Header XML must not be modified.",
      "Footer must be output using XPath XML.",
      "Dynamic base templates are structure locked."
    ],
    "locks": [
      {
        "target": "header",
        "policy": "scss_only"
      },
      {
        "target": "footer",
        "policy": "xpath_required"
      },
      {
        "target": "templates/base-dynamic-products.xml",
        "policy": "structure_locked"
      }
    ]
  },
  "outputs": {
    "files": [
      {
        "type": "xml",
        "path": "outputs/page-YYYYMMDD-HHMM.xml",
        "required": true
      },
      {
        "type": "scss",
        "path": "outputs/page-YYYYMMDD-HHMM.scss",
        "required": true
      }
    ]
  }
}
