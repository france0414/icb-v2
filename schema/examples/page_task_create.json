{
  "version": "v1.0",
  "command": "/create",
  "task_type": "page",
  "intent_summary": "Create a new page after confirming a text skeleton.",
  "output_mode": "qweb_full",
  "resources": {
    "docs": [
      "resources/layout_patterns.md",
      "resources/snippet_catalog.md"
    ]
  },
  "constraints": {
    "rules": [
      "Phase A: output text skeleton first.",
      "Generate XML/SCSS only after user confirmation."
    ],
    "locks": []
  },
  "outputs": {
    "files": [
      {
        "type": "xml",
        "path": "outputs/create-YYYYMMDD-HHMM.xml",
        "required": true
      },
      {
        "type": "scss",
        "path": "outputs/create-YYYYMMDD-HHMM.scss",
        "required": true
      }
    ]
  }
}
